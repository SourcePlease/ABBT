# ─────────────────────────────────────────────────────────────────────────────
# Bot Configs — fill these in before running. NEVER commit real values.
# ─────────────────────────────────────────────────────────────────────────────
API_ID=""
API_HASH=""
BOT_TOKEN=
MAX_WORKERS=2
ENCODE_CHUNK=20
ENDING_BUTTONS=
ENDING_IMAGE=assets/ending.png

# Completed anime (batch bot)
BATCH_BOT_TOKEN=
BATCH_MAIN_CHANNEL=
BATCH_FILE_STORE=

# Movies
MOVIE_BOT_TOKEN=
MOVIE_MAIN_CHANNEL=
MOVIE_FILE_STORE=
MOVIE_LOG_CHANNEL=
MOVIE_RSS_ITEMS=""

# Database
MONGO_URI=
DB_NAME=ani_bot_001
BATCH_DB_NAME=ani_bot_002
MOVIE_DB_NAME=anime_movies

# Channels
FSUB_CHATS=""
BACKUP_CHANNEL=""
MAIN_CHANNEL=
LOG_CHANNEL=
FILE_STORE=
OWNER=
OWNER_ID=

# Bot Settings
RSS_ITEMS="https://subsplease.org/rss/?r=1080"
SEND_SCHEDULE="True"
BRAND_UNAME=""

QUALS=Hdri 1080 720 480

# Encoding presets — multi-threaded, animation-tuned
FFCODE_Hdri=ffmpeg -hwaccel auto -i '{}' -progress '{}' -nostats -loglevel warning -map 0:v -map 0:a -map 0:s:m:language:eng? -c:v libx264 -pix_fmt yuv420p -vf "scale=640:360:flags=lanczos" -crf 32 -preset veryfast -tune animation -threads 1 -x264-params threads=1 -c:a libopus -b:a 48k -ac 2 -c:s copy -movflags +faststart '{}' -y
FFCODE_1080=ffmpeg -hwaccel auto -i '{}' -progress '{}' -nostats -loglevel warning -map 0:v -map 0:a -map 0:s:m:language:eng? -c:v libx264 -pix_fmt yuv420p -vf "scale=1920:1080:flags=bicubic" -crf 24 -preset superfast -tune animation -c:a libopus -b:a 128k -c:s copy '{}' -y
FFCODE_720=ffmpeg -hwaccel auto -i '{}' -progress '{}' -nostats -loglevel warning -map 0:v -map 0:a -map 0:s:m:language:eng? -c:v libx264 -pix_fmt yuv420p -vf "scale=1280:720:flags=bicubic" -crf 25 -preset ultrafast -tune animation -c:a libopus -b:a 96k -c:s copy '{}' -y
FFCODE_480=ffmpeg -hwaccel auto -i '{}' -progress '{}' -nostats -loglevel warning -map 0:v -map 0:a -map 0:s:m:language:eng? -c:v libx264 -pix_fmt yuv420p -vf "scale=854:480:flags=bicubic" -crf 27 -preset ultrafast -tune animation -c:a libopus -b:a 64k -c:s copy '{}' -y

# Customisation
AS_DOC="True"
AUTO_DEL="True"
DEL_TIMER="600"
START_PHOTO="assets/start.png"
SETTINGS_PHOTO_URL=""
START_MSG="<b>Hi {first_name}, welcome to the bot.</b>"
START_BUTTONS=""

# Update — point to your own fork; use a fine-grained PAT scoped to repo:read
UPSTREAM_REPO=""
UPSTREAM_BRANCH="main"
